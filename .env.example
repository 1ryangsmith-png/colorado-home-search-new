# Copy this file to .env and fill in your values
# These are set as Environment Variables in Netlify (Site Settings → Environment Variables)

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Google Maps
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-key-here

# App config
VITE_APP_NAME=Colorado Home Search
VITE_DEFAULT_LAT=39.5186
VITE_DEFAULT_LNG=-104.7614
VITE_DEFAULT_ZOOM=11

# Optional: RapidAPI for real estate data (get free key at rapidapi.com)
# RAPIDAPI_KEY=your-rapidapi-key-here
